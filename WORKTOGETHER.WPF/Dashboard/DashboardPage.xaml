<Page x:Class="WORKTOGETHER.WPF.Dashboard.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E7A" Padding="15,10">
            <TextBlock Text="DASHBOARD" Foreground="White"
                       FontSize="14" FontWeight="Bold"/>
        </Border>

        <!-- Cartes statistiques -->
        <Grid Grid.Row="1" Margin="15,15,15,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2C3E7A" CornerRadius="8" Margin="0,0,8,0" Padding="15">
                <StackPanel>
                    <TextBlock Text=" Clients" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="TxtNbClients" Text="0" Foreground="White"
                               FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#1A5276" CornerRadius="8" Margin="4,0,4,0" Padding="15">
                <StackPanel>
                    <TextBlock Text=" Baies" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="TxtNbBaies" Text="0" Foreground="White"
                               FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#1E8449" CornerRadius="8" Margin="4,0,4,0" Padding="15">
                <StackPanel>
                    <TextBlock Text=" Commandes payées" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="TxtNbCommandes" Text="0" Foreground="White"
                               FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="#922B21" CornerRadius="8" Margin="8,0,0,0" Padding="15">
                <StackPanel>
                    <TextBlock Text=" Tickets ouverts" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="TxtNbTickets" Text="0" Foreground="White"
                               FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tableaux -->
        <Grid Grid.Row="2" Margin="15,0,15,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Dernières commandes"
                           FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" x:Name="DgDernieresCommandes"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          AlternatingRowBackground="#F5F5F5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Numéro" Binding="{Binding NumeroCommande}" Width="*"/>
                        <DataGridTextColumn Header="Client" Binding="{Binding Client.Nom}" Width="*"/>
                        <DataGridTextColumn Header="Statut" Binding="{Binding StatutPaiement}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Tickets ouverts"
                           FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" x:Name="DgTicketsOuverts"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          AlternatingRowBackground="#F5F5F5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Numéro" Binding="{Binding NumeroTicket}" Width="*"/>
                        <DataGridTextColumn Header="Sujet" Binding="{Binding Sujet}" Width="*"/>
                        <DataGridTextColumn Header="Priorité" Binding="{Binding Priorite}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Page>