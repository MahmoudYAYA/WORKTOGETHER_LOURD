<Window x:Class="WORKTOGETHER.WPF.Views.NouvelleUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nouvelle Utilisateur" Height="450" Width="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Nouvelle Utilisateur"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

       
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Nom *" FontWeight="Bold"/>
            <TextBox x:Name="TxtNom" Padding="8,5"/>
        </StackPanel>
        
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Prénom *" FontWeight="Bold"/>
            <TextBox x:Name="TxtPrenom" Padding="8,5"/>
        </StackPanel>
        
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Email *" FontWeight="Bold"/>
            <TextBox x:Name="TxtEmail" Padding="8,5"/>
        </StackPanel>
        
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Password *" FontWeight="Bold"/>
            <PasswordBox x:Name="Password" Padding="8,5"/>
        </StackPanel>

        <!-- Type utilisateur -->
        <StackPanel Grid.Row="5" Margin="0,0,0,10">
            <TextBlock Text="Type *" FontWeight="Bold"/>
            <ComboBox x:Name="CmbType" Padding="8,5">
                <ComboBoxItem Content="Admin" Tag="ROLE_ADMIN"/>
                <ComboBoxItem Content="Comptable" Tag="ROLE_COMPTABLE"/>
                <ComboBoxItem Content="Cleint" Tag="ROLE_CLIENT"/>
            </ComboBox>
        </StackPanel>

        <!-- Boutons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler" Padding="15,8" Margin="0,0,10,0"
                    Click="BtnAnnuler_Click"/>
            <Button Content=" Créer" Padding="15,8" Background="#1E8449"
                    Foreground="White" Click="BtnCreer_Click"/>
        </StackPanel>
    </Grid>
</Window>