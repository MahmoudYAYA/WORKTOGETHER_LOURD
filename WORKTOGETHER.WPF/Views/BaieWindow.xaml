<Window x:Class="WORKTOGETHER.WPF.Views.BaieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion des baies" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Text="Liste des Baies" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Tableau -->
        <DataGrid Grid.Row="1" 
                  x:Name="DgBaies"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="LightGray">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Numéro" Binding="{Binding NumeroBaie}" Width="150"/>
                <DataGridTextColumn Header="Nom" Binding="{Binding NomBaie}" Width="200"/>
                <DataGridTextColumn Header="Capacité totale" Binding="{Binding CapaciteTotal}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>