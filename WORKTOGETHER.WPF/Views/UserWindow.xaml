<Window x:Class="WORKTOGETHER.WPF.Views.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion des Utilisateurs" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Titre -->
            <RowDefinition Height="Auto"/>
            <!-- Bouton -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0"
                   Text="Liste des Utilisateurs"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- ✅ Bouton (BON ENDROIT) -->
        <Button Grid.Row="1"
                Content="➕ Nouvel utilisateur"
                HorizontalAlignment="Right"
                Padding="12,6"
                Margin="0,0,0,10"
                Background="#2C3E7A"
                Foreground="White"
                Click="BtnNouveau_Click"/>

        <!-- Tableau -->
        <DataGrid Grid.Row="2"
                  x:Name="DgUtilisateurs"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="LightGray">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="150"/>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="200"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="Role" Binding="{Binding RoleLabel}" Width="150"/>
                <DataGridTextColumn Header="Active" Binding="{Binding ActifLabel}" Width="150"/>
                <DataGridTemplateColumn Header="Actions" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!-- Bouton Toggle -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding ActifLabel}"
                        Click="BtnToggle_Click"
                        Tag="{Binding Id}"
                        Padding="8,4" Margin="2"/>

                                <!-- Bouton Supprimer -->
                                <Button Content="🗑️ Supprimer"
                        Click="BtnSupprimer_Click"
                        Tag="{Binding Id}"
                        Padding="8,4" Margin="2"
                        Background="#922B21"
                        Foreground="White"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

        </DataGrid>
    
    </Grid>
</Window>