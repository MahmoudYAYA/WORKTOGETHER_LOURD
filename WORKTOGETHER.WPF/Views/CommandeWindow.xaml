<Window x:Class="WORKTOGETHER.WPF.Views.CommandeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion des Commandes" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Text="Liste des Commandes" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Tableau -->
        <DataGrid Grid.Row="1" 
                  x:Name="DgCommandes"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="LightGray">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Numéro commande" Binding="{Binding NumeroCommande}" Width="150"/>
                <DataGridTextColumn Header="Nom d'offre" Binding="{Binding Offre.NomOffre}" Width="150"/>
                <DataGridTextColumn Header="Client" Binding="{Binding Client.Nom}" Width="150"/>
                <DataGridTextColumn Header="Montant HT" Binding="{Binding MontantTotal}" Width="120"/>
                <DataGridTextColumn Header="Montant TVA" Binding="{Binding MontantTva}" Width="120"/>
                <DataGridTextColumn Header="Statut" Binding="{Binding StatutPaiement}" Width="120"/>
                <DataGridTextColumn Header="Date début" Binding="{Binding DateDebutService, StringFormat=dd/MM/yyyy}" Width="120"/>
                <DataGridTextColumn Header="Date fin" Binding="{Binding DateFinService, StringFormat=dd/MM/yyyy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>