<Window x:Class="WORKTOGETHER.WPF.Views.NouvelleInterventionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nouvelle Intervention" Height="450" Width="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Nouvelle Intervention"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Titre -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Titre *" FontWeight="Bold"/>
            <TextBox x:Name="TxtTitre" Padding="8,5"/>
        </StackPanel>

        <!-- Type -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Type *" FontWeight="Bold"/>
            <ComboBox x:Name="CmbType" Padding="8,5">
                <ComboBoxItem Content="Maintenance" Tag="1"/>
                <ComboBoxItem Content="Remplacement" Tag="2"/>
                <ComboBoxItem Content="Autre" Tag="3"/>
            </ComboBox>
        </StackPanel>

        <!-- Description -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Description" FontWeight="Bold"/>
            <TextBox x:Name="TxtDescription" Padding="8,5" Height="80"
                     TextWrapping="Wrap" AcceptsReturn="True"/>
        </StackPanel>

        <!-- Unité -->
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Unité concernée *" FontWeight="Bold"/>
            <ComboBox x:Name="CmbUnite" Padding="8,5"
                      DisplayMemberPath="NomUnite"/>
        </StackPanel>

        <!-- Date début -->
        <StackPanel Grid.Row="5" Margin="0,0,0,10">
            <TextBlock Text="Date de début *" FontWeight="Bold"/>
            <DatePicker x:Name="DpDateDebut"/>
        </StackPanel>

        <!-- Boutons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler" Padding="15,8" Margin="0,0,10,0"
                    Click="BtnAnnuler_Click"/>
            <Button Content="✅ Créer" Padding="15,8" Background="#1E8449"
                    Foreground="White" Click="BtnCreer_Click"/>
        </StackPanel>
    </Grid>
</Window>