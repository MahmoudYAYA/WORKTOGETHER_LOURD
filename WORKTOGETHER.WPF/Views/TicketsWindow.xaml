<Window x:Class="WORKTOGETHER.WPF.Views.TicketsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion des Tickets" Height="500" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Liste des Tickets" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <DataGrid Grid.Row="1" 
                  x:Name="DgTickets"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  AlternatingRowBackground="LightGray">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Numéro" Binding="{Binding NumeroTicket}" Width="120"/>
                <DataGridTextColumn Header="Sujet" Binding="{Binding Sujet}" Width="150"/>
                <DataGridTextColumn Header="Priorité" Binding="{Binding Priorite}" Width="80"/>
                <DataGridTextColumn Header="Client" Binding="{Binding Client.Nom}" Width="120"/>
                <DataGridTextColumn Header="Statut" Binding="{Binding StatutLabel}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Date création" Binding="{Binding DateCreation, StringFormat=dd/MM/yyyy}" Width="120"/>

                <!-- Bouton Fermer -->
                <DataGridTemplateColumn Header="Actions" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Fermer"
                                    Click="BtnFermer_Click"
                                    Tag="{Binding Id}"
                                
                                    Margin="2"
                                    />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>