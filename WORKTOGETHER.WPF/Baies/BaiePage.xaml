<Page x:Class="WORKTOGETHER.WPF.Baies.BaiePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Baies">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="#2C3E7A" Padding="15,10">
            <TextBlock Text="BAIES" Foreground="White"
                       FontSize="14" FontWeight="Bold"/>
        </Border>

        <!-- Contenu -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════ LISTE ══════════════ -->
            <Grid Grid.Column="0" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Boutons -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="CRÉER" Padding="12,6" Margin="0,0,5,0"
                            Background="#2C3E7A" Foreground="White" BorderThickness="0"
                            Click="BtnCreer_Click"/>
                    <Button Content="SUPPRIMER" Padding="12,6" Margin="0,0,5,0"
                            Background="#922B21" Foreground="White" BorderThickness="0"
                            Click="BtnSupprimer_Click"/>
                </StackPanel>

                <!-- Tableau -->
                <DataGrid Grid.Row="1" x:Name="DgBaies"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionChanged="DgBaies_SelectionChanged"
                          AlternatingRowBackground="#F5F5F5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NUMÉRO" Binding="{Binding NumeroBaie}" Width="*"/>
                        <DataGridTextColumn Header="CAPACITÉ" Binding="{Binding CapaciteTotale}" Width="100"/>
                        <DataGridTextColumn Header="OCCUPÉES" Binding="{Binding NbUnitesOccupees}" Width="100"/>
                        <DataGridTextColumn Header="DISPONIBLES" Binding="{Binding NbUnitesDisponibles}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ══════════════ FORMULAIRE ══════════════ -->
            <Border Grid.Column="1" Background="#F8F9FA"
                    BorderBrush="#DDDDDD" BorderThickness="1,0,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Titre formulaire -->
                    <Border Grid.Row="0" Background="#2C3E7A" Padding="10,8" Margin="0,0,0,20">
                        <TextBlock x:Name="TxtTitreFormulaire" Text="FORMULAIRE"
                                   Foreground="White" FontWeight="Bold"/>
                    </Border>

                    <!-- Champs -->
                    <StackPanel Grid.Row="1">

                        <!-- Numéro baie -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Numéro *" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="TxtNumeroBaie" Padding="6,4"/>
                        </Grid>

                        <!-- Capacité -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Capacité *" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="TxtCapacite" Padding="6,4"/>
                        </Grid>

                        <!-- Info création unités -->
                        <TextBlock Text="ℹ️ Les unités seront créées automatiquement"
                                   Foreground="#5D6D7E" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,5,0,0"/>

                        <!-- Message erreur -->
                        <TextBlock x:Name="TxtErreur" Foreground="Red"
                                   TextWrapping="Wrap" Margin="0,10,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Boutons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="ANNULER" Padding="12,6" Margin="0,0,8,0"
                                BorderThickness="1" Click="BtnAnnuler_Click"/>
                        <Button Content="ENREGISTRER" Padding="12,6"
                                Background="#2C3E7A" Foreground="White" BorderThickness="0"
                                Click="BtnEnregistrer_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>