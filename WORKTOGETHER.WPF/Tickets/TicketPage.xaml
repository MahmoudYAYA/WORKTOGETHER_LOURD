<Page x:Class="WORKTOGETHER.WPF.Tickets.TicketPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Tickets">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- En-tête -->
            <RowDefinition Height="*"/>
            <!-- Contenu -->
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="#2C3E7A" Padding="15,10">
            <TextBlock Text="TICKETS SUPPORT" Foreground="White"
                       FontSize="14" FontWeight="Bold"/>
        </Border>

        <!-- Contenu : Liste + Formulaire -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Liste -->
                <ColumnDefinition Width="400"/>
                <!-- Formulaire -->
            </Grid.ColumnDefinitions>

            <!-- ══════════════ LISTE ══════════════ -->
            <Grid Grid.Column="0" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Boutons -->
                    <RowDefinition Height="*"/>
                    <!-- DataGrid -->
                </Grid.RowDefinitions>

                <!-- Boutons d'action -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="CRÉER" Padding="12,6" Margin="0,0,5,0"
                            Background="#2C3E7A" Foreground="White" BorderThickness="0"
                            Click="BtnCreer_Click"/>
                    <Button Content="FERMER" Padding="12,6" Margin="0,0,5,0"
                            Background="#1E8449" Foreground="White" BorderThickness="0"
                            Click="BtnFermer_Click"/>
                    <Button Content="SUPPRIMER" Padding="12,6" Margin="0,0,5,0"
                            Background="#922B21" Foreground="White" BorderThickness="0"
                            Click="BtnSupprimer_Click"/>
                </StackPanel>

                <!-- Tableau des tickets -->
                <DataGrid Grid.Row="1" x:Name="DgTickets"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionChanged="DgTickets_SelectionChanged"
                          AlternatingRowBackground="#F5F5F5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NUMÉRO" Binding="{Binding NumeroTicket}" Width="120"/>
                        <DataGridTextColumn Header="SUJET" Binding="{Binding Sujet}" Width="*"/>
                        <DataGridTextColumn Header="PRIORITÉ" Binding="{Binding Priorite}" Width="80"/>
                        <DataGridTextColumn Header="CLIENT" Binding="{Binding Client.Nom}" Width="120"/>
                        <DataGridTextColumn Header="STATUT" Binding="{Binding StatutLabel}" Width="100"/>
                        <DataGridTextColumn Header="DATE" Binding="{Binding DateCreation, StringFormat=dd/MM/yyyy}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ══════════════ FORMULAIRE ══════════════ -->
            <Border Grid.Column="1" Background="#F8F9FA"
                    BorderBrush="#DDDDDD" BorderThickness="1,0,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Titre -->
                        <RowDefinition Height="*"/>
                        <!-- Champs -->
                        <RowDefinition Height="Auto"/>
                        <!-- Boutons -->
                    </Grid.RowDefinitions>

                    <!-- Titre formulaire -->
                    <Border Grid.Row="0" Background="#2C3E7A" Padding="10,8" Margin="0,0,0,20">
                        <TextBlock x:Name="TxtTitreFormulaire" Text="FORMULAIRE"
                                   Foreground="White" FontWeight="Bold"/>
                    </Border>

                    <!-- Champs -->
                    <StackPanel Grid.Row="1">

                        <!-- Sujet -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Sujet *" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="TxtSujet" Padding="6,4"/>
                        </Grid>

                        <!-- Description -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Description" VerticalAlignment="Top" Margin="0,5,0,0"/>
                            <!-- Zone multiligne -->
                            <TextBox Grid.Column="1" x:Name="TxtDescription"
                                     Padding="6,4" Height="80"
                                     TextWrapping="Wrap" AcceptsReturn="True"/>
                        </Grid>

                        <!-- Priorité -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Priorité *" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="CmbPriorite" Padding="6,4">
                                <ComboBoxItem Content="Basse"  Tag="1"/>
                                <ComboBoxItem Content="Moyenne" Tag="2"/>
                                <ComboBoxItem Content="Haute"  Tag="3"/>
                            </ComboBox>
                        </Grid>

                        <!-- Client -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Client *" VerticalAlignment="Center"/>
                            <!-- DisplayMemberPath → affiche l'email du client -->
                            <ComboBox Grid.Column="1" x:Name="CmbClient"
                                      Padding="6,4" DisplayMemberPath="Email"/>
                        </Grid>

                        <!-- Message erreur -->
                        <TextBlock x:Name="TxtErreur" Foreground="Red"
                                   TextWrapping="Wrap" Margin="0,5,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Boutons Annuler / Enregistrer -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="ANNULER" Padding="12,6" Margin="0,0,8,0"
                                BorderThickness="1" Click="BtnAnnuler_Click"/>
                        <Button Content="ENREGISTRER" Padding="12,6"
                                Background="#2C3E7A" Foreground="White" BorderThickness="0"
                                Click="BtnEnregistrer_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>