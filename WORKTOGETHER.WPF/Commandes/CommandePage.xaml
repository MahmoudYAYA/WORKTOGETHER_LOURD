<Page x:Class="WORKTOGETHER.WPF.Commandes.CommandePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Commandes">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- En-tête -->
            <RowDefinition Height="*"/>
            <!-- Contenu -->
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="#2C3E7A" Padding="15,10">
            <TextBlock Text="COMMANDES" Foreground="White"
                       FontSize="14" FontWeight="Bold"/>
        </Border>

        <!-- Contenu : Liste + Détail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Liste -->
                <ColumnDefinition Width="400"/>
                <!-- Détail -->
            </Grid.ColumnDefinitions>

            <!-- ══════════════ LISTE ══════════════ -->
            <Grid Grid.Column="0" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Boutons -->
                    <RowDefinition Height="*"/>
                    <!-- DataGrid -->
                </Grid.RowDefinitions>

                <!-- Boutons d'action -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="ANNULER COMMANDE" Padding="12,6" Margin="0,0,5,0"
                            Background="#922B21" Foreground="White" BorderThickness="0"
                            Click="BtnAnnuler_Click"/>
                </StackPanel>

                <!-- Tableau des commandes -->
                <DataGrid Grid.Row="1" x:Name="DgCommandes"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionChanged="DgCommandes_SelectionChanged"
                          AlternatingRowBackground="#F5F5F5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NUMÉRO" Binding="{Binding NumeroCommande}" Width="150"/>
                        <DataGridTextColumn Header="CLIENT" Binding="{Binding Client.Nom}" Width="120"/>
                        <DataGridTextColumn Header="OFFRE" Binding="{Binding Offre.NomOffre}" Width="120"/>
                        <DataGridTextColumn Header="MONTANT" Binding="{Binding MontantTotal}" Width="100"/>
                        <DataGridTextColumn Header="STATUT" Binding="{Binding StatutPaiement}" Width="120"/>
                        <DataGridTextColumn Header="DATE" Binding="{Binding DateCommande, StringFormat=dd/MM/yyyy}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ══════════════ DÉTAIL ══════════════ -->
            <Border Grid.Column="1" Background="#F8F9FA"
                    BorderBrush="#DDDDDD" BorderThickness="1,0,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Titre -->
                        <RowDefinition Height="*"/>
                        <!-- Détails -->
                    </Grid.RowDefinitions>

                    <!-- Titre -->
                    <Border Grid.Row="0" Background="#2C3E7A" Padding="10,8" Margin="0,0,0,20">
                        <TextBlock x:Name="TxtTitreDetail" Text="DÉTAIL COMMANDE"
                                   Foreground="White" FontWeight="Bold"/>
                    </Border>

                    <!-- Informations de la commande -->
                    <StackPanel Grid.Row="1" x:Name="PanelDetail">

                        <!-- Numéro commande -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Numéro :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtNumero" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Client -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Client :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtClient" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Offre -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Offre :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtOffre" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Type paiement -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Type paiement :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtTypePaiement" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Montant HT -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Montant HT :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtMontantHT" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Montant TVA -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="TVA :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtTVA" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Statut paiement -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Statut :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtStatut" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Date début service -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Début service :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtDateDebut" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Date fin service -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Fin service :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtDateFin" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Séparateur -->
                        <Separator Margin="0,10,0,10"/>
                        <TextBlock Text="🖥️ Unités réservées" FontWeight="Bold" Margin="0,0,0,8"/>

                        <DataGrid x:Name="DgUnites"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          CanUserAddRows="False"
          MaxHeight="200"
          AlternatingRowBackground="#F5F5F5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NUMÉRO" Binding="{Binding NumeroUnite}" Width="*"/>
                                <DataGridTextColumn Header="NOM" Binding="{Binding NomUnite}" Width="*"/>
                                <DataGridTextColumn Header="ÉTAT" Binding="{Binding Etat}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Carte bancaire si payé -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Carte :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtCarte" VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>