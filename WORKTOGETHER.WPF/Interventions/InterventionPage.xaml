<Page x:Class="WORKTOGETHER.WPF.Interventions.InterventionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Interventions">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- En-tête -->
            <RowDefinition Height="*"/>
            <!-- Contenu -->
        </Grid.RowDefinitions>

        <!-- En-tête bleu -->
        <Border Grid.Row="0" Background="#2C3E7A" Padding="15,10">
            <TextBlock Text="INTERVENTIONS" Foreground="White"
                       FontSize="14" FontWeight="Bold"/>
        </Border>

        <!-- Contenu : Liste à gauche, Formulaire à droite -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Liste -->
                <ColumnDefinition Width="400"/>
                <!-- Formulaire -->
            </Grid.ColumnDefinitions>

            <!-- ══════════════ LISTE ══════════════ -->
            <Grid Grid.Column="0" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Boutons -->
                    <RowDefinition Height="*"/>
                    <!-- DataGrid -->
                </Grid.RowDefinitions>

                <!-- Boutons d'action -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="BtnCreer" Content="CRÉER"
                            Padding="12,6" Margin="0,0,5,0"
                            Background="#2C3E7A" Foreground="White" BorderThickness="0"
                            Click="BtnCreer_Click"/>
                    <Button x:Name="BtnTerminer" Content="TERMINER"
                            Padding="12,6" Margin="0,0,5,0"
                            Background="#1E8449" Foreground="White" BorderThickness="0"
                            Click="BtnTerminer_Click"/>
                    <Button x:Name="BtnSupprimer" Content="SUPPRIMER"
                            Padding="12,6" Margin="0,0,5,0"
                            Background="#922B21" Foreground="White" BorderThickness="0"
                            Click="BtnSupprimer_Click"/>
                </StackPanel>

                <!-- Tableau des interventions -->
                <DataGrid Grid.Row="1" x:Name="DgInterventions"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionChanged="DgInterventions_SelectionChanged"
                          AlternatingRowBackground="#F5F5F5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TITRE" Binding="{Binding Titre}" Width="*"/>
                        <DataGridTextColumn Header="TYPE" Binding="{Binding TypeLabel}" Width="120"/>
                        <DataGridTextColumn Header="STATUT" Binding="{Binding StatutLabel}" Width="120"/>
                        <DataGridTextColumn Header="UNITÉ" Binding="{Binding Unite.NomUnite}" Width="120"/>
                        <DataGridTextColumn Header="DÉBUT" Binding="{Binding DateDebut, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="FIN" Binding="{Binding DateFin, StringFormat=dd/MM/yyyy}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ══════════════ FORMULAIRE ══════════════ -->
            <Border Grid.Column="1" Background="#F8F9FA"
                    BorderBrush="#DDDDDD" BorderThickness="1,0,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Titre formulaire -->
                        <RowDefinition Height="*"/>
                        <!-- Champs -->
                        <RowDefinition Height="Auto"/>
                        <!-- Boutons -->
                    </Grid.RowDefinitions>

                    <!-- Titre formulaire -->
                    <Border Grid.Row="0" Background="#2C3E7A" Padding="10,8" Margin="0,0,0,20">
                        <TextBlock x:Name="TxtTitreFormulaire" Text="FORMULAIRE"
                                   Foreground="White" FontWeight="Bold"/>
                    </Border>

                    <!-- Champs du formulaire -->
                    <StackPanel Grid.Row="1">

                        <!-- Champ Titre -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Titre *" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="TxtTitre" Padding="6,4"/>
                        </Grid>

                        <!-- Champ Type -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Type *" VerticalAlignment="Center"/>
                            <!-- Liste déroulante pour le type -->
                            <ComboBox Grid.Column="1" x:Name="CmbType" Padding="6,4">
                                <ComboBoxItem Content="Maintenance"  Tag="1"/>
                                <ComboBoxItem Content="Remplacement" Tag="2"/>
                                <ComboBoxItem Content="Autre"        Tag="3"/>
                            </ComboBox>
                        </Grid>

                        <!-- Champ Description -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Description" VerticalAlignment="Top" Margin="0,5,0,0"/>
                            <!-- Zone de texte multiligne -->
                            <TextBox Grid.Column="1" x:Name="TxtDescription"
                                     Padding="6,4" Height="80"
                                     TextWrapping="Wrap" AcceptsReturn="True"/>
                        </Grid>

                        <!-- Champ Unité -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Unité *" VerticalAlignment="Center"/>
                            <!-- DisplayMemberPath → affiche NomUnite dans la liste -->
                            <ComboBox Grid.Column="1" x:Name="CmbUnite"
                                      Padding="6,4" DisplayMemberPath="NomUnite"/>
                        </Grid>

                        <!-- Champ Date début -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Date début *" VerticalAlignment="Center"/>
                            <!-- Sélecteur de date -->
                            <DatePicker Grid.Column="1" x:Name="DpDateDebut"/>
                        </Grid>

                        <!-- Message d'erreur (caché par défaut) -->
                        <TextBlock x:Name="TxtErreur" Foreground="Red"
                                   TextWrapping="Wrap" Margin="0,5,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Boutons Annuler / Enregistrer -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="ANNULER" Padding="12,6" Margin="0,0,8,0"
                                BorderThickness="1" Click="BtnAnnuler_Click"/>
                        <Button Content="ENREGISTRER" Padding="12,6"
                                Background="#2C3E7A" Foreground="White" BorderThickness="0"
                                Click="BtnEnregistrer_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>